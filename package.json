{
  "name": "feishu-bridge-poc",
  "version": "0.2.0",
  "description": "A PoC exploring how collaboration tools should be redesigned for the AI Agent era — exposing Feishu capabilities through both CLI and MCP forms, sharing a unified AI Friendly design philosophy.",
  "type": "module",
  "bin": {
    "feishu-bridge": "./dist/cli/index.js",
    "feishu-bridge-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "start:mcp": "node dist/mcp/server.js",
    "start:cli": "node dist/cli/index.js",
    "ping": "tsx src/cli/index.ts ping"
  },
  "keywords": [
    "feishu",
    "lark",
    "mcp",
    "ai-friendly",
    "agent",
    "cli",
    "claude",
    "cursor"
  ],
  "author": "PeterGuy326",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
