# Copy this file to .env and fill in your Feishu app credentials.
# Get them at https://open.feishu.cn/app -> your app -> 凭证与基础信息

FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the API base URL (default: https://open.feishu.cn/open-apis)
# FEISHU_BASE_URL=
